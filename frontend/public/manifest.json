      "url": "/?action=search",
      "icons": [{ "src": "/icons/search.png", "sizes": "96x96" }]
    },
    {
      "name": "播放列表",
      "short_name": "播放列表",
      "description": "查看播放列表",
      "url": "/?tab=playlist",
      "icons": [{ "src": "/icons/playlist.png", "sizes": "96x96" }]
    }
  ],
  "categories": ["entertainment", "music", "video"],
